) AS pivot(anyo_nac NUMERIC, hombres BIGINT, mujeres BIGINT);

--128. Doctores sin personal en su misma especialidad 
SELECT d.apellido, d.especialidad, h.nombre AS hospital 
FROM doctor d, hospital h 
WHERE d.hospital_cod = h.hospital_cod 
AND NOT EXISTS ( 
SELECT 1 FROM plantilla p, sala s 
WHERE p.hospital_cod = d.hospital_cod 
AND p.funcion = d.especialidad 
) 
ORDER BY h.nombre, d.apellido; 

--129. Coeficiente de variación de salarios por departamento 
SELECT d.dnombre, 
COUNT(e.salario) AS num_empleados, 
ROUND(AVG(e.salario), 2) AS media, 
ROUND(STDDEV(e.salario), 2) AS desviacion, 
ROUND(STDDEV(e.salario)::NUMERIC / NULLIF(AVG(e.salario), 0) * 100, 2) 
AS cv_porcentaje 
FROM dept2 d, emp e  
WHERE d.dept_no = e.dept_no 
GROUP BY d.dnombre 
ORDER BY cv_porcentaje DESC; 

--130. Empleados con mismo oficio y departamento que su 
--jefe 
SELECT e.apellido AS empleado, e.oficio,  
j.apellido AS jefe, j.oficio AS oficio_jefe, 
e.dept_no 
FROM emp e, emp j  
WHERE e.dir = j.emp_no  
AND e.oficio = j.oficio 
AND e.dept_no = j.dept_no; 

--131. Empleados que ganan menos del 80% del promedio de 
--su oficio 
-- Ver los empleados afectados 
SELECT e.apellido, e.oficio, e.salario,  
ROUND(avg_oficio.media_oficio, 2) AS media_oficio, 
ROUND(e.salario::NUMERIC / avg_oficio.media_oficio * 100, 2) 
AS porcentaje 
FROM emp e, (SELECT oficio, AVG(salario) AS media_oficio FROM emp 
GROUP BY oficio) avg_oficio 
WHERE e.oficio = avg_oficio.oficio  
AND e.salario < avg_oficio.media_oficio * 0.8; -- Actualización 
UPDATE emp e  
SET salario = salario * 1.15 
FROM (SELECT oficio, AVG(salario) AS media_oficio FROM emp GROUP BY oficio) avg_oficio 
WHERE e.oficio = avg_oficio.oficio  
AND e.salario < avg_oficio.media_oficio * 0.8;

--132. Números de cama disponibles por sala 
SELECT s.hospital_cod, s.sala_cod, generate_series(1, s.num_cama) 
AS cama_numero,
CASE WHEN o.cama IS NOT NULL THEN 'OCUPADA' ELSE 'LIBRE' END AS estado 
FROM sala s 
LEFT JOIN ocupacion o ON s.hospital_cod = o.hospital_cod  
AND s.sala_cod = o.sala_cod  
AND generate_series(1, s.num_cama) = o.cama 
ORDER BY s.hospital_cod, s.sala_cod, cama_numero;

--133. Salario acumulado por departamento 
SELECT apellido, dept_no, oficio, salario, 
SUM(salario) OVER (PARTITION BY dept_no ORDER BY salario)
AS salario_acumulado, 
ROUND(salario::NUMERIC / SUM(salario) OVER (PARTITION BY dept_no) * 100, 2) 
AS porcentaje_departamento 
FROM emp  
ORDER BY dept_no, salario; 

--134. Jerarquía de empleados (Recursive CTE) 
WITH RECURSIVE jerarquia (emp_no, apellido, nivel, camino) 
AS ( 
-- Nivel base: empleados sin jefe (PRESIDENTE) 
SELECT emp_no, apellido, 1 AS nivel, apellido AS camino 
FROM emp  
WHERE dir IS NULL 
UNION ALL 
-- Nivel recursivo 
SELECT e.emp_no, e.apellido, j.nivel + 1,  j.camino || ' -> ' || e.apellido 
AS camino 
FROM emp e, jerarquia j 
WHERE e.dir = j.emp_no 
) 
SELECT apellido, nivel, camino 
FROM jerarquia  
ORDER BY nivel, apellido; 

--135. Vista de informe ejecutivo completo 
DROP VIEW IF EXISTS informe_ejecutivo CASCADE;

CREATE VIEW informe_ejecutivo AS
SELECT  
h.hospital_cod, 
h.nombre AS hospital, 
h.num_cama AS camas_totales, 
COUNT(DISTINCT s.sala_cod) AS total_salas, 
COUNT(DISTINCT p.empleado_no) AS total_personal, 
ROUND(AVG(p.salario), 2) AS salario_medio_personal, 
COUNT(DISTINCT d.doctor_no) AS total_doctores, 
COUNT(DISTINCT e.inscripcion) AS pacientes_actuales, 
ROUND(
        COUNT(DISTINCT e.inscripcion)::NUMERIC 
        / NULLIF(h.num_cama, 0) * 100, 2
    ) AS ocupacion_porcentaje, 

    COUNT(DISTINCT CASE 
        WHEN UPPER(p.funcion) = 'MÉDICO' 
        THEN p.empleado_no 
    END) AS num_medicos, 

    COUNT(DISTINCT CASE 
        WHEN UPPER(p.funcion) IN ('ENFERMERO', 'ENFERMERA') 
        THEN p.empleado_no 
    END) AS num_enfermeros, 

    COUNT(DISTINCT CASE 
        WHEN UPPER(d.especialidad) = 'CARDIOLOGÍA' 
        THEN d.doctor_no 
    END) AS cardiologos, 

    COUNT(DISTINCT CASE 
        WHEN UPPER(d.especialidad) = 'PEDIATRÍA' 
        THEN d.doctor_no 
    END) AS pediatras, 

    MAX(p.salario) AS salario_maximo, 
    MIN(p.salario) AS salario_minimo 

FROM hospital h 
LEFT JOIN sala s ON h.hospital_cod = s.hospital_cod 
LEFT JOIN plantilla p ON h.hospital_cod = p.hospital_cod 
LEFT JOIN doctor d ON h.hospital_cod = d.hospital_cod 
LEFT JOIN ocupacion o ON h.hospital_cod = o.hospital_cod 
LEFT JOIN enfermo e ON o.inscripcion = e.inscripcion 

GROUP BY h.hospital_cod, h.nombre, h.num_cama 
ORDER BY hospital;
