--TAREA

--1. Miembros del personal cuyo nombre empiece por 'H' 
SELECT apellido FROM plantilla WHERE UPPER(apellido) LIKE 'H%'; 

--2. Enfermeras y enfermeros en turnos de Tarde o Mañana 
SELECT apellido  
FROM plantilla  
WHERE UPPER(funcion) IN ('ENFERMERO', 'ENFERMERA')  
  AND UPPER(turno) IN ('T', 'M'); 
  
--3. Enfermeras que ganan entre 2.000.000 y 2.500.000 
SELECT apellido, salario  
FROM plantilla  
WHERE salario BETWEEN 2000000 AND 2500000  
  AND UPPER(funcion) = 'ENFERMERA'; 
  
--4. Abreviatura de tres letras de hospitales 
SELECT SUBSTRING(nombre FROM 1 FOR 3) AS abr, hospital_cod, nombre  
FROM hospital  
ORDER BY 1; 

--5. Asignar códigos a especialidades (CASE en Postgre) 
SELECT apellido, especialidad, 
       CASE especialidad 
           WHEN 'Cardiología' THEN 1 
           WHEN 'Psiquiatría' THEN 2 
           WHEN 'Pediatría' THEN 3 
           ELSE 4 
       END AS codigo 
FROM doctor; 

--6. Posición de la primera letra 'A' en el apellido 
SELECT apellido, POSITION('A' IN apellido) AS "PRIMERA LETRA A"  
FROM enfermo; 

--7. Formatear información de departamentos 
SELECT 'El departamento de ' || dnombre || ' está en ' || loc AS comentario  FROM dept2; 

--8. Reemplazar primera 'N' del apellido por 'nnn' 
SELECT OVERLAY(apellido PLACING 'nnn' FROM POSITION('N' IN apellido) FOR 1) AS "TRES N" 
--Overlay reemplaza una parte del texto original solo para visualizar
FROM emp  
WHERE UPPER(apellido) LIKE '%N%'  
ORDER BY apellido; 

--9. Salario total y dígitos que lo componen
SELECT apellido,
 salario + COALESCE(comision, 0) AS sal_total,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 1, 1) AS c,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 2, 1) AS d,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 3, 1) AS m,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 4, 1) AS c,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 5, 1) AS d,
 SUBSTRING(CAST(salario + COALESCE(comision, 0) AS VARCHAR), 6, 1) AS u
FROM emp
ORDER BY 2 DESC, 1;

--10. Salario total con comisión o 15% del salario
SELECT apellido,oficio,salario + COALESCE(comision, salario * 0.15) AS salario_total
FROM emp
WHERE comision IS NULL OR comision > salario * 0.15
ORDER BY oficio, 3 DESC;

--11. Salario mensual de enfermeras y enfermeros
SELECT apellido, TRUNC(salario / 12) AS "SALARIO MENSUAL"
FROM plantilla
WHERE UPPER(funcion) IN ('ENFERMERA', 'ENFERMERO');

--12. Fecha de hace tres semanas
SELECT CURRENT_DATE - 21 AS fecha;

--13. Personal del departamento 20 con salario > 150,000 mensuales
SELECT apellido, oficio,
 TO_CHAR(fecha_alt, 'day month dd " de " yyyy hh24:mi') AS alta
FROM emp
WHERE dept_no = 20 AND salario > 150000;

--14. Empleados dados de alta entre martes y jueves
SELECT emp_no, oficio, TO_CHAR(fecha_alt, 'day') AS dia
FROM emp
WHERE EXTRACT(DOW FROM fecha_alt) BETWEEN 2 AND 4; -- Lunes=1, Martes=2, Miércoles=3, Jueves=4

--15. Días de alta formateados en español
SELECT apellido, oficio,
 CASE EXTRACT(DOW FROM fecha_alt)
 WHEN 1 THEN 'Lunes'
 WHEN 2 THEN 'Martes'
 WHEN 3 THEN 'Miércoles'
 WHEN 4 THEN 'Jueves'
 WHEN 5 THEN 'Viernes'
 ELSE 'Fin de semana'
 END AS dia
FROM emp
ORDER BY 3;

--16. Salario medio de los Analistas
SELECT round(AVG(salario), 2) AS "SALARIO MEDIO" FROM emp WHERE UPPER(oficio) = 'ANALISTA';

--17. Salario más alto, más bajo y su diferencia
SELECT MAX(salario) AS maximo,
 MIN(salario) AS minimo,
 MAX(salario) - MIN(salario) AS diferencia
FROM emp;

--18. Número de oficios diferentes en departamentos 10 y 20
SELECT COUNT(DISTINCT oficio) AS tareas
FROM emp
WHERE dept_no IN (10, 20);

--19. Número de personas por oficio y departamento
SELECT dept_no, oficio, COUNT(*)
FROM emp
GROUP BY dept_no, oficio;

--20. Departamentos con más de 4 personas
SELECT dept_no, COUNT(*) AS personal
FROM emp
GROUP BY dept_no
HAVING COUNT(*) > 4;

--21. Departamentos con más de 2 personas en la misma profesión
SELECT dept_no, oficio, COUNT(*) AS personal
FROM emp
GROUP BY dept_no, oficio
HAVING COUNT(*) > 2;

--22. Número de empleados por departamento con oficio'EMPLEADO'
SELECT dept_no, COUNT(*)
FROM emp
WHERE UPPER(oficio) = 'EMPLEADO'
GROUP BY dept_no;

--23. Salario total medio anual de los vendedores
SELECT oficio, AVG(salario + COALESCE(comision, 0)) AS "SALARIO MEDIO ANUAL"
FROM emp
WHERE UPPER(oficio) = 'VENDEDOR'
GROUP BY oficio;

--24. Salario total medio anual de empleados y vendedores
SELECT oficio, round(AVG(salario + COALESCE(comision, 0)),2) AS "SALARIO MEDIO ANUAL"
FROM emp
WHERE UPPER(oficio) IN ('VENDEDOR', 'EMPLEADO')
GROUP BY oficio;

--25. Por departamento y oficio, máximo y suma salarial
SELECT dept_no, oficio, SUM(salario) AS suma, MAX(salario) AS maximo
FROM emp
WHERE (comision IS NULL) OR (comision < 0.25 * salario)
GROUP BY dept_no, oficio
HAVING SUM(salario) >= 0.5 * MAX(salario);

--26. Por año y oficio (solo días laborables)
SELECT EXTRACT(YEAR FROM fecha_alt) AS alta,oficio,COUNT(*) AS "N1 EMPL", round(AVG(salario),2) AS "MEDIA SALARIAL"
FROM emp
WHERE EXTRACT(DOW FROM fecha_alt) NOT IN (0, 6) -- Postgre: 0=Domingo, 6=Sábado
GROUP BY EXTRACT(YEAR FROM fecha_alt), oficio
HAVING COUNT(*) > 1
ORDER BY 1, 4 DESC;

--27. Máximo salario por inicial consonante
SELECT SUBSTRING(apellido FROM 1 FOR 1) AS inicial, MAX(salario) AS maximo
FROM emp
WHERE POSITION('N' IN apellido) = 0 OR POSITION('N' IN SUBSTRING(apellido FROM POSITION('N' IN apellido) + 1))= 0
GROUP BY SUBSTRING(apellido FROM 1 FOR 1)
HAVING SUBSTRING(apellido FROM 1 FOR 1) NOT IN ('A','E','I','O','U')
ORDER BY 1;

--28. Matriz de salarios por oficio y departamento
SELECT oficio,
 SUM(CASE WHEN dept_no = 10 THEN salario ELSE 0 END) AS dep10,
 SUM(CASE WHEN dept_no = 20 THEN salario ELSE 0 END) AS dep20,
 SUM(CASE WHEN dept_no = 30 THEN salario ELSE 0 END) AS dep30,
 SUM(CASE WHEN dept_no = 40 THEN salario ELSE 0 END) AS dep40,
 SUM(salario) AS total
FROM emp
GROUP BY oficio
ORDER BY 6 DESC;

--29. Suma de comisiones asignando porcentaje pordepartamento
SELECT dept_no, oficio,
 SUM(COALESCE(comision,
 CASE dept_no
 WHEN 10 THEN 0.1 * salario
 WHEN 20 THEN 0.15 * salario
 WHEN 30 THEN 0.17 * salario
 ELSE 0.05 * salario
 END)) AS "SUMA DE COMISIONES"
FROM emp
WHERE EXTRACT(YEAR FROM fecha_alt) <= 1981
 AND UPPER(oficio) != 'PRESIDENTE'
GROUP BY dept_no, oficio;

--30. Máximo, mínimo y media por departamento (formatovertical)
SELECT 'Maximo---' AS comentario, MAX(salario) AS valor, dept_no
FROM emp GROUP BY dept_no
UNION
SELECT 'Media---' AS comentario, AVG(salario) AS valor, dept_no
FROM emp GROUP BY dept_no
UNION
SELECT 'Minimo---' AS comentario, MIN(salario) AS valor, dept_no
FROM emp GROUP BY dept_no
ORDER BY 3;

--31. Empleados con nombre de departamento
SELECT apellido, oficio, e.dept_no, dnombre
FROM emp e, dept2 d
WHERE e.dept_no = d.dept_no;

--32. Analistas y localidad donde trabajan
SELECT apellido, oficio, loc
FROM emp e, dept2 d
WHERE e.dept_no = d.dept_no
 AND UPPER(oficio) = 'ANALISTA';

--33. Empleados que trabajan en Madrid
SELECT apellido, oficio
FROM emp e, dept2 d
WHERE UPPER(loc) = 'MADRID'
 AND e.dept_no = d.dept_no
ORDER BY oficio;

--34. Número de empleados por departamento
SELECT e.dept_no AS num_dep, dnombre AS departamento, COUNT(*) AS n1_empl
FROM emp e, dept2 d
WHERE e.dept_no = d.dept_no
GROUP BY e.dept_no, dnombre
ORDER BY 3 DESC;

--35. Estadísticas para VENTAS y CONTABILIDAD
SELECT dnombre,
 MAX(salario) AS maximo,
 MIN(salario) AS minimo,
 AVG(salario) AS media,
 COUNT(*) AS n_empl
FROM emp e, dept2 d
WHERE UPPER(dnombre) IN ('VENTAS', 'CONTABILIDAD')
 AND e.dept_no = d.dept_no
GROUP BY dnombre
ORDER BY dnombre;

--36. Máximo salario por sala y hospital
SELECT h.nombre AS hospital, s.nombre AS sala, MAX(p.salario) AS maximo
FROM sala s, plantilla p, hospital h
WHERE h.hospital_cod = p.hospital_cod
 AND p.hospital_cod = s.hospital_cod
 AND p.sala_cod = s.sala_cod
GROUP BY h.nombre, s.nombre;

--37. Empleados con su jefe directo
SELECT e.emp_no AS empleado, e.apellido AS nombre, e.oficio, e.dir AS jefe, e2.apellido AS nombre_jefe, e2.oficio AS oficio_jefe
FROM emp e, emp e2
WHERE e.dir = e2.emp_no
ORDER BY 2;

--38. Mínimo salario por departamento, excluyendo'EMPLEADO'
SELECT dnombre AS departamento, COALESCE(MIN(salario), 0) AS minimo
FROM emp e, dept2 d
WHERE e.dept_no = d.dept_no
 AND (UPPER(oficio) != 'EMPLEADO' OR oficio IS NULL)
GROUP BY dnombre
ORDER BY 2 DESC;

--39. Empleados con jefe (incluyendo al director general)
SELECT e.emp_no AS empleado, e.apellido AS nombre, e.oficio, e.dir AS jefe, e2.apellido AS nombre_jefe, e2.oficio AS oficio_jefe
FROM emp e
LEFT JOIN emp e2 ON e.dir = e2.emp_no
ORDER BY 2;

--40. Outer join para mostrar jefes sin subordinados
SELECT e.emp_no AS empleado, e.apellido AS nombre, e.oficio, e.dir AS jefe, e2.apellido AS nombre_jefe, e2.oficio AS oficio_jefe
FROM emp e
RIGHT JOIN emp e2 ON e.dir = e2.emp_no
ORDER BY 2;

--41. Combinación de los dos anteriores
SELECT e.emp_no AS empleado, e.apellido AS nombre, e.oficio, e.dir AS jefe, e2.apellido AS nombre_jefe, e2.oficio AS oficio_jefe
FROM emp e
LEFT JOIN emp e2 ON e.dir = e2.emp_no
UNION
SELECT e.emp_no AS empleado, e.apellido AS nombre, e.oficio, e.dir AS jefe, e2.apellido AS nombre_jefe, e2.oficio AS oficio_jefe
FROM emp e
RIGHT JOIN emp e2 ON e.dir = e2.emp_no
ORDER BY 2;

