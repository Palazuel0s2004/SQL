--Bloque de consultas
-- Clientes que más dinero han gastado
SELECT c.nombre, c.email, SUM(dp.precio_unitario * dp.cantidad) AS total_gastado
FROM clientes c
JOIN pedidos p ON c.cliente_id = p.cliente_id
JOIN detalles_pedidos dp ON p.pedido_id = dp.pedido_id
GROUP BY c.cliente_id, c.nombre, c.email
ORDER BY total_gastado DESC;

-- Productos con stock crítico (menos de 5 unidades)
SELECT nombre_producto, stock, precio 
FROM productos 
WHERE stock < 5;

-- Producto más vendido en total de unidades
SELECT pr.nombre_producto, SUM(dp.cantidad) AS unidades_vendidas
FROM productos pr
JOIN detalles_pedidos dp ON pr.producto_id = dp.producto_id
GROUP BY pr.producto_id, pr.nombre_producto
ORDER BY unidades_vendidas DESC
LIMIT 1;
